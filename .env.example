# ============================================
# WhatsApp Cloud API
# ============================================
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=mon_token_secret_webhook

# ============================================
# Instagram Messaging API
# ============================================
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_PAGE_ID=your_page_id_here

# ============================================
# Meta Ads Marketing API
# ============================================
META_USER_TOKEN=your_meta_user_token_here
META_AD_ACCOUNT_ID=act_your_ad_account_id_here

# ============================================
# Stripe
# ============================================
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here

# ============================================
# Growth Automation — Daily Report Scheduler
# ============================================
# Hour (0-23, Paris timezone) to run the daily report
DAILY_REPORT_HOUR=8
# Period for the daily report: last_7d | last_14d | last_30d
DAILY_REPORT_PRESET=last_7d
# WhatsApp number to receive the daily report (international format, e.g. 33612345678)
NOTIFICATION_PHONE=

# ============================================
# Serveur
# ============================================
PORT=3000
